# Copie este arquivo para .env e ajuste os valores

# Banco de dados PostgreSQL (pgAdmin local)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/cafeteria_db"

# JWT Secret (troque por uma string aleatória segura)
JWT_SECRET="cafeteria_jwt_secret_troque_em_producao"

# Porta do servidor
PORT=3001
